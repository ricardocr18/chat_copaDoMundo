# Variáveis de ambiente (NUNCA commite!)
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Poetry
poetry.lock   # Pode commitar se quiser reproducibilidade exata

# Pytest / Coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# Mypy
.mypy_cache/
.dmypy.json

# IDEs
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Dados processados (ChromaDB) - gerado localmente
app/data/processed/chroma_db/

# Logs
*.log
logs/

# AWS
.aws/

# Pasta zGeral
zGeral/
*zGeral/

