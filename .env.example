# ── AWS / Bedrock ─────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here

# Modelo Claude no Bedrock (não mude sem testar disponibilidade na sua região)
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_EMBEDDINGS_MODEL_ID=amazon.titan-embed-text-v2:0

# ── LangFuse (Observabilidade) ────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=your-public-key
LANGFUSE_SECRET_KEY=your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Aplicação ─────────────────────────────────────────────────────────────────
APP_ENV=development         # development | production
APP_NAME=world-cup-agent
LOG_LEVEL=DEBUG             # DEBUG | INFO | WARNING | ERROR

# ── Vector Store ──────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./app/data/processed/chroma_db
